    RowBox[{"P", ".", " ", "There"}], " ", "are", " ", "hidden", " ", 
    "factors", " ", "of", " ", "V", " ", "which", " ", "actually", " ", 
    "give", " ", "dimension"}], ",", " ", 
   RowBox[{
   "but", " ", "they", " ", "get", " ", "divided", " ", "by", " ", "again", 
    " ", "hidden", " ", "factors", " ", "of", " ", "V", " ", "in", " ", "the",
     " ", "integrations"}]}], "*)"}]], "Input",
