Cell[CellGroupData[{

Cell["\<\
Resonance Decays
\
\>", "Subsection",
 CellChangeTimes->{{3.952424433664008*^9, 
  3.952424451350604*^9}},ExpressionUUID->"2a94f66b-218a-4fe4-9cf6-\
08601665b85c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Load", " ", "and", " ", "clean", " ", "file"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"lines", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"\"\<decays_PDG2021Plus_ThFIST.dat\>\"", ",", "\"\<Lines\>\""}],
       "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cleaned", "=", 
     RowBox[{"StringTrim", "/@", 
      RowBox[{"Select", "[", 
       RowBox[{"lines", ",", 
        RowBox[{
         RowBox[{"StringMatchQ", "[", 
          RowBox[{"#", ",", 
           RowBox[{
            RowBox[{"Except", "[", "\"\<#\>\"", "]"}], "~~", "___"}]}], "]"}],
          "&"}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"blocks", "=", 
     RowBox[{"SplitBy", "[", 
      RowBox[{"cleaned", ",", 
       RowBox[{
        RowBox[{"#", "=!=", "\"\<\>\""}], "&"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"blocks", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"blocks", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "=!=", "\"\<\>\""}], "&"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Proton", " ", "PDG", " ", "ID"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"protonIDR", "=", "2212"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Step", " ", "1"}], ":", 
     RowBox[{"Parse", " ", "into", " ", "association"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"decayRules", "=", 
     RowBox[{"Association", "@", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"pdg", ",", "n", ",", "channels", ",", "parsedChannels"}], 
           "}"}], ",", 
          RowBox[{
           RowBox[{"pdg", "=", 
            RowBox[{"ToExpression", "[", 
             RowBox[{"block", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"n", "=", 
            RowBox[{"ToExpression", "[", 
             RowBox[{"block", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"channels", "=", 
            RowBox[{"block", "[", 
             RowBox[{"[", 
              RowBox[{"3", ";;", 
               RowBox[{"2", "+", "n"}]}], "]"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"parsedChannels", "=", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Module", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"parts", "=", 
                  RowBox[{"StringSplit", "[", "ch", "]"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"ToExpression", "[", 
                   RowBox[{"parts", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
                  RowBox[{"ToExpression", "/@", 
                   RowBox[{"parts", "[", 
                    RowBox[{"[", 
                    RowBox[{"2", ";;"}], "]"}], "]"}]}]}], "}"}]}], "]"}], 
              ",", 
              RowBox[{"{", 
               RowBox[{"ch", ",", "channels"}], "}"}]}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"pdg", "->", "parsedChannels"}]}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"block", ",", "blocks"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Step", " ", "2"}], ":", 
     RowBox[{
     "Recursively", " ", "compute", " ", "total", " ", "probability", " ", 
      "of", " ", "ending", " ", "in", " ", "a", " ", "proton"}]}], "*)"}], 
   "\n", 
   RowBox[{"ClearAll", "[", "ProtonProb", "]"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"ProtonProb", "[", "pid_", "]"}], ":=", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"ProtonProb", "[", "pid", "]"}], "="}], "*)"}], 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"channels", ",", 
         RowBox[{"prob", "=", "0"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"pid", "===", "protonIDR"}], ",", 
          RowBox[{"Return", "[", "1.", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"KeyExistsQ", "[", 
            RowBox[{"decayRules", ",", "pid"}], "]"}]}], ",", 
          RowBox[{"Return", "[", "0.", "]"}]}], "]"}], ";", 
        RowBox[{"(*", 
         RowBox[{"stable", " ", "or", " ", "unknown"}], "*)"}], 
        RowBox[{"channels", "=", 
         RowBox[{"decayRules", "[", "pid", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"br", ",", "daughters", ",", "daughterProbs"}], "}"}], 
            ",", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"br", ",", "daughters"}], "}"}], "=", "ch"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"daughterProbs", "=", 
              RowBox[{"1", "-", 
               RowBox[{"Times", "@@", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"1", "-", 
                    RowBox[{"ProtonProb", "[", "#", "]"}]}], "&"}], "/@", 
                  "daughters"}], ")"}]}]}]}], ";", 
             RowBox[{"(*", 
              RowBox[{
              "probability", " ", "that", " ", "at", " ", "least", " ", "one",
                " ", "daughter", " ", "leads", " ", "to", " ", "proton"}], 
              "*)"}], 
             RowBox[{"prob", "+=", 
              RowBox[{"br", "*", "daughterProbs"}]}], ";"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"ch", ",", "channels"}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", "prob"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Example", ":", 
     RowBox[{
