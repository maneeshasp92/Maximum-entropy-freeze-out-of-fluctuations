Cell[CellGroupData[{

Cell["Gas Factorial Cumulants", "Section",
 CellChangeTimes->{{3.9269456401586514`*^9, 
  3.926945645472831*^9}},ExpressionUUID->"aaa3f557-68c4-430d-b73c-\
6f8284515b28"],

Cell[CellGroupData[{

Cell["Equations", "Subsection",
 CellChangeTimes->{{3.932025510526574*^9, 
  3.932025511804585*^9}},ExpressionUUID->"6c5a20ea-b2b2-48eb-b8ae-\
2e46ae7b8cb2"],

Cell[TextData[{
 "Irreducible Relative Cumulants of the Hadron Resonance Gas are calculated \
from the Hydrodynamic Irreducible Relative Cumulants using the expression:\n\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"OverHat", "[", "\[CapitalDelta]", "]"}], 
    SubscriptBox["G", "AA"]}], TraditionalForm]],ExpressionUUID->
  "f168c882-739e-438b-ae27-805cc33b4cba"],
 "=",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"OverHat", "[", "\[CapitalDelta]", "]"}], 
    SubscriptBox["H", "ab"]}], TraditionalForm]],ExpressionUUID->
  "e8dc03c9-b1f8-40e6-abea-d7dbb550629e"],
 " (OverBar[H])^(-1)_{ac}P^{c}_{C}OverBar[G]_{CA} \
(OverBar[H])^(-1)_{bd}P^{d}_{D}OverBar[G]_{DA}\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"OverHat", "[", "\[CapitalDelta]", "]"}], 
    SubscriptBox["G", "AAA"]}], TraditionalForm]],ExpressionUUID->
  "626f0ad4-aa64-47f3-ae2f-ffe7b40e01f3"],
 "=",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"OverHat", "[", "\[CapitalDelta]", "]"}], 
    SubscriptBox["H", "abc"]}], TraditionalForm]],ExpressionUUID->
  "b51c00c1-359d-4d00-8f1e-94c42b192612"],
 "  (OverBar[H])^(-1)_{ae}P^{e}_{C}OverBar[G]_{CA} \
(OverBar[H])^(-1)_{bd}P^{d}_{D}OverBar[G]_{DA} \
(OverBar[H])^(-1)_{bf}P^{f}_{D}OverBar[G]_{DA}\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"OverHat", "[", "\[CapitalDelta]", "]"}], 
    SubscriptBox["G", "AAAA"]}], TraditionalForm]],ExpressionUUID->
  "5f3f4d52-9049-45ed-bf8b-4fb0ee00a466"],
 "=",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"OverHat", "[", "\[CapitalDelta]", "]"}], "d"}], 
   TraditionalForm]],ExpressionUUID->"f682cbbf-d56a-407e-b4e2-d384abdf2949"],
 "  (OverBar[H])^(-1)_{ae}P^{e}_{C}OverBar[G]_{CA} \
(OverBar[H])^(-1)_{be}P^{e}_{L}OverBar[G]_{LA} \
(OverBar[H])^(-1)_{dh}P^{h}_{E}OverBar[G]_{EA}(OverBar[H])^(-1)_{bf}P^{f}_{D}\
OverBar[G]_{DA}\n\nNp2, Np3,Np4 are IRCs for protons integrated over phase \
space and normalized by mean proton multiplicity\n Np3Del,Np4Del are IRCs for \
protons, (obtained by approximating the hydrodynamic IRCs with their cumulant \
values) integrated over phase space and normalized by mean proton multiplicity"
}], "Abstract",
 CellChangeTimes->{{3.9270170106638412`*^9, 3.927017222888845*^9}, {
  3.9270172577771187`*^9, 3.927017391782631*^9}, {3.9270174279513083`*^9, 
  3.927017490109887*^9}},ExpressionUUID->"b26d6de0-27e6-4de3-8512-\
b3e56b8b694d"],

