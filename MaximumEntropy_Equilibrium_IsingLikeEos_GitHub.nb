Cell[BoxData[{
 RowBox[{
  RowBox[{"protonID", "=", "18"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"KineticCoefficient", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"2", 
        RowBox[{"\[Pi]", "^", "2"}]}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}]}], 
     RowBox[{"TcGeV", "^", 
      RowBox[{"(", 
       RowBox[{"-", "3"}], ")"}]}], 
     RowBox[{"sortedHadronProperties", "[", 
      RowBox[{"[", 
       RowBox[{"protonID", ",", "3"}], "]"}], "]"}], 
     RowBox[{"Dot", "[", 
      RowBox[{"H\[Epsilon]n2InverseATCP", ",", 
       RowBox[{"NIntegrate", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Gi2", "[", 
           RowBox[{"protonID", ",", "p", ",", "\[Mu]cGeV", ",", "TcGeV"}], 
           "]"}], 
          RowBox[{"p", "^", "2"}], "*", 
          RowBox[{"Hvec", "[", 
           RowBox[{"\[Mu]cGeV", ",", "TcGeV", ",", "protonID"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"p", ",", "0", ",", "\[Infinity]"}], "}"}]}], "]"}]}], 
      "]"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ProtonNumberDensitybyT3", "[", 
   RowBox[{"u_", ",", "T_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", 
      RowBox[{"\[Pi]", "^", "2"}]}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{"-", "1"}], ")"}]}], 
   RowBox[{"TcGeV", "^", 
    RowBox[{"(", 
     RowBox[{"-", "3"}], ")"}]}], 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"sortedHadronProperties", "[", 
       RowBox[{"[", 
        RowBox[{"protonID", ",", "4"}], "]"}], "]"}], "*", 
      RowBox[{"sortedHadronProperties", "[", 
       RowBox[{"[", 
        RowBox[{"protonID", ",", "3"}], "]"}], "]"}], 
      RowBox[{"(", 
       RowBox[{"fA", "[", 
        RowBox[{"protonID", ",", "p", ",", "u", ",", "T"}], "]"}], ")"}], 
      RowBox[{"p", "^", "2"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"p", ",", "0", ",", "\[Infinity]"}], "}"}]}], 
    "]"}]}]}]}], "Input",
