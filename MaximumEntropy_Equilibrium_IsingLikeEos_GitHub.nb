   RowBox[{
   "All", " ", "hydrodynamic", " ", "correlation", " ", "functions", " ", 
    "below", " ", "are", " ", "made", " ", "dimensionless", " ", "by", " ", 
    "dividing", " ", "by", " ", "appropriate", " ", "factors", " ", "of", " ",
     "Tc", " ", "and", " ", "taking", " ", "derivatives", " ", "of", " ", 
    RowBox[{"P", "/", 
